class BankAccount:
    def __init__(self, account_number, pin, balance=0):
        self.account_number = account_number
        self.pin = pin
        self.balance = balance
        self.transaction_history = []

    def check_balance(self):
        return self.balance

    def deposit(self, amount):
        if amount > 0:
            self.balance += amount
            self.transaction_history.append(f"存款: +{amount:.2f} 余额: {self.balance:.2f}")
            return True
        return False

    def withdraw(self, amount):
        if 0 < amount <= self.balance:
            self.balance -= amount
            self.transaction_history.append(f"取款: -{amount:.2f} 余额: {self.balance:.2f}")
            return True
        return False

    def get_transaction_history(self):
        return self.transaction_history


class ATM:
    def __init__(self):
        self.accounts = {
            "123456": BankAccount("123456", "1234", 1000),
            "654321": BankAccount("654321", "4321", 5000)
        }
        self.current_account = None

    def authenticate(self, account_number, pin):
        if account_number in self.accounts and self.accounts[account_number].pin == pin:
            self.current_account = self.accounts[account_number]
            return True
        return False

    def logout(self):
        self.current_account = None

    def run(self):
        print("欢迎使用银行ATM系统")

        while True:
            if not self.current_account:
                print("\n请插入银行卡或输入账号(输入q退出): ")
                account_number = input("账号: ")
                if account_number.lower() == 'q':
                    break

                pin = input("密码: ")
                if self.authenticate(account_number, pin):
                    print(f"\n登录成功! 欢迎账户 {account_number}")
                else:
                    print("账号或密码错误，请重试")
                    continue
            else:
                print("\n请选择操作:")
                print("1. 查询余额")
                print("2. 存款")
                print("3. 取款")
                print("4. 交易记录")
                print("5. 退出")

                choice = input("请输入选项(1-5): ")

                if choice == '1':
                    balance = self.current_account.check_balance()
                    print(f"\n当前余额: {balance:.2f}元")

                elif choice == '2':
                    try:
                        amount = float(input("请输入存款金额: "))
                        if self.current_account.deposit(amount):
                            print(f"\n存款成功! 当前余额: {self.current_account.check_balance():.2f}元")
                        else:
                            print("存款金额必须大于0")
                    except ValueError:
                        print("请输入有效的金额")

                elif choice == '3':
                    try:
                        amount = float(input("请输入取款金额: "))
                        if self.current_account.withdraw(amount):
                            print(f"\n取款成功! 当前余额: {self.current_account.check_balance():.2f}元")
                        else:
                            print("取款金额无效或余额不足")
                    except ValueError:
                        print("请输入有效的金额")

                elif choice == '4':
                    print("\n交易记录:")
                    for transaction in self.current_account.get_transaction_history():
                        print(transaction)
                    if not self.current_account.get_transaction_history():
                        print("暂无交易记录")

                elif choice == '5':
                    print("\n感谢使用，再见!")
                    self.logout()
                    break

                else:
                    print("无效选项，请重新输入")


if __name__ == "__main__":
    atm = ATM()
    atm.run()
